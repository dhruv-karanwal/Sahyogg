  <Document>
    <name>SAHYOG: Ultra-Detailed Amphan Intelligence</name>
    <open>1</open>
    <description>Profoundly enriched multi-layer Liquid Galaxy Demo (Track, Polygons, Centers)</description>
    
    <Folder><name>Cyclone Track (Time-Series)</name>
      <Style id="trackLine"><LineStyle><color>ff0000ff</color><width>6</width></LineStyle></Style>
      <Style id="trackPoint">
