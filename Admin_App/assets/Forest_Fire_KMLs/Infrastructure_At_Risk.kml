<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Infrastructure At Risk</name>
    <Folder>
      <name>Infrastructure At Risk</name>

      <Style id="houseIcon">
        <IconStyle><scale>1.3</scale><Icon><href>http://maps.google.com/mapfiles/kml/shapes/lodging.png</href></Icon></IconStyle>
        <LabelStyle><color>ff0000ff</color><scale>1.1</scale></LabelStyle>
      </Style>

      <Placemark>
        <name>Pauri Village Settlements (At Risk)</name>
        <styleUrl>#houseIcon</styleUrl>
        <Point><coordinates>78.8,30.15,0</coordinates></Point>
      </Placemark>

      <Placemark>
        <name>Nainital Suburban Houses (Evacuated)</name>
        <styleUrl>#houseIcon</styleUrl>
        <Point><coordinates>79.45,29.39,0</coordinates></Point>
      </Placemark>

      <Placemark>
        <name>Tehri Hydro Dam Facilities (Surrounded by Fire)</name>
        <styleUrl>#houseIcon</styleUrl>
        <Point><coordinates>78.5,30.38,0</coordinates></Point>
      </Placemark>

      <Placemark>
        <name>Almora Rural Homes (Under threat)</name>
        <styleUrl>#houseIcon</styleUrl>
        <Point><coordinates>79.6,29.6,0</coordinates></Point>
      </Placemark>

      <Style id="infraRiskPoly"><PolyStyle><color>600000ff</color></PolyStyle><LineStyle><color>ff0000ff</color><width>2</width></LineStyle></Style>
      <Placemark>
        <name>Critical Infrastructure Threat Zone (6 lives lost, 31 injured)</name>
        <styleUrl>#infraRiskPoly</styleUrl>
        <Polygon><outerBoundaryIs><LinearRing><coordinates>
          78.2,29.3,0 79.8,29.3,0 79.5,30.5,0 78.0,30.5,0 78.2,29.3,0
        </coordinates></LinearRing></outerBoundaryIs></Polygon>
      </Placemark>

    </Folder>
  </Document>
</kml>