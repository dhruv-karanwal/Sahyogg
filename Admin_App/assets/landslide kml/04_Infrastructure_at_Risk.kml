        <name>Infrastructure at Risk</name>
        <Placemark id="54">
            <name>Malin Village Base</name>
            <description>Ground zero. Over 40 houses completely submerged in debris.</description>
            <styleUrl>#55</styleUrl>
            <Point id="53">
